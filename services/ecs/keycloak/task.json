{
    "containerDefinitions": [
        {
            "name": "keycloak",
            "image": "keycloak",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "keycloak-8080-tcp",
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "command": [
                "start",
                "--optimized"
            ],
            "environment": [
                {
                    "name": "KC_PROXY_HEADERS",
                    "value": "xforwarded"
                },
                {
                    "name": "KC_DB_PASSWORD",
                    "value": "password"
                },
                {
                    "name": "KEYCLOAK_ADMIN_PASSWORD",
                    "value": "password"
                },
                {
                    "name": "KC_HTTP_MANAGEMENT_HEALTH_ENABLED",
                    "value": "false"
                },
                {
                    "name": "KC_DB_USERNAME",
                    "value": "postgres"
                },
                {
                    "name": "KC_PROXY",
                    "value": "edge"
                },
                {
                    "name": "KC_DB",
                    "value": "postgres"
                },
                {
                    "name": "KEYCLOAK_ADMIN",
                    "value": "admin"
                },
                {
                    "name": "KC_DB_URL_HOST",
                    "value": "dms-3.c3jn0kosadjl.us-east-1.rds.amazonaws.com"
                },
                {
                    "name": "KC_HTTP_ENABLED",
                    "value": "true"
                },
                {
                    "name": "KC_DB_URL_DATABASE",
                    "value": "keycloak"
                },
                {
                    "name": "KC_DB_URL_PORT",
                    "value": "5432"
                },
                {
                    "name": "KC_DB_SCHEMA",
                    "value": "public"
                },
                {
                    "name": "KC_HOSTNAME",
                    "value": "cognito-4-1857216914.us-east-1.elb.amazonaws.com"
                }
            ],
            "mountPoints": [],
            "volumesFrom": []
        }
    ],
    "family": "keycloak-fargate",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",

    "tags": []
}